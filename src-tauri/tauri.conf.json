{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rosetta",
  "version": "0.3.5",
  "identifier": "com.rosetta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rosetta",
        "width": 800,
        "height": 600,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5MThCNzVEODJEREYwQzQKUldURThOMkNYYmNZT1hodU1NWnhlU09vdXpqNHh4TThWVnJWbGVBVTRUblFtSjdORmI1T1lRTG0K",
      "endpoints": [
        "https://github.com/somnifex/Rosetta/releases/latest/download/latest.json"
      ]
    }
  }
}
